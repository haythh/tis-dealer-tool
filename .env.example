# Browser-safe canonical app URL used for SMS result links.
NEXT_PUBLIC_APP_URL=https://inventory.teamtis.com

# Optional Twilio webhook signature validation.
# Keep false for quick local demos; set true in production after adding TWILIO_AUTH_TOKEN in Railway.
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_AUTH_TOKEN=

# Optional override if Twilio should receive result links on a different public domain.
TWILIO_PUBLIC_BASE_URL=https://inventory.teamtis.com

# Existing Dealer Tool parser key, server-only.
GEMINI_API_KEY=
